        <pose>0.05 0 0.23 0 0 0</pose>
        <geometry>
          <box>
            <size>0.95 0.62 0.10</size>
          </box>
        </geometry>
        <material>
          <ambient>0.88 0.46 0.12 1</ambient>
          <diffuse>0.96 0.52 0.16 1</diffuse>
