      <sensor name="base_imu" type="imu">
        <pose>0 0 0.28 0 0 0</pose>
        <topic>/ugv_1/imu</topic>
        <always_on>true</always_on>
        <update_rate>100</update_rate>
      </sensor>
    </link>

    <link name="left_front_wheel">
      <pose>0.42 0.48 0.22 1.5708 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.04</ixx>
          <iyy>0.04</iyy>
          <izz>0.04</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.22</radius>
            <length>0.16</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.22</radius>
            <length>0.16</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.03 0.03 0.03 1</diffuse>
        </material>
