<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="inspection_rover">
    <static>false</static>
    <self_collide>false</self_collide>

    <link name="base_link">
      <pose>0 0 0.32 0 0 0</pose>
      <inertial>
        <mass>38.0</mass>
        <inertia>
          <ixx>2.0</ixx>
          <iyy>3.0</iyy>
          <izz>3.8</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="chassis_collision">
        <geometry>
          <box>
            <size>1.25 0.82 0.34</size>
          </box>
        </geometry>
      </collision>

      <visual name="chassis_visual">
