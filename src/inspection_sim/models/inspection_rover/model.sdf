            <size>1.25 0.82 0.34</size>
          </box>
        </geometry>
        <material>
          <ambient>0.10 0.14 0.15 1</ambient>
          <diffuse>0.13 0.20 0.21 1</diffuse>
          <specular>0.05 0.07 0.08 1</specular>
