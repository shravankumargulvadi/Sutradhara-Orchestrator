ARG BASE_IMAGE=osrf/ros:jazzy-simulation

FROM ${BASE_IMAGE} AS base

SHELL ["/bin/bash", "-lc"]

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8
ENV PIP_BREAK_SYSTEM_PACKAGES=1
ENV UV_CACHE_DIR=/tmp/uv-cache

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    cmake \
    curl \
    git \
    gnupg \
    libasio-dev \
    libtinyxml2-dev \
    lsb-release \
    ninja-build \
    python3-colcon-common-extensions \
    python3-dev \
    python3-pip \
    python3-rosdep \
    python3-setuptools \
    python3-vcstool \
    python3-venv \
    python3-wheel \
    software-properties-common \
    wget \
    && rm -rf /var/lib/apt/lists/*

COPY docker/ros_entrypoint.sh /usr/local/bin/ros2_ws_ai_entrypoint.sh
RUN chmod +x /usr/local/bin/ros2_ws_ai_entrypoint.sh

FROM base AS deps-src

COPY docker/dependencies.repos /tmp/dependencies.repos

RUN mkdir -p /opt/src /opt/underlay_ws/src /opt/xrce_ws/src && \
    vcs import /opt/src < /tmp/dependencies.repos && \
    mv /opt/src/external/PX4-Autopilot /opt/px4 && \
    mv /opt/src/external/underlay_ws/src/px4_msgs /opt/underlay_ws/src/ && \
    mv /opt/src/external/xrce_ws/src/Micro-XRCE-DDS-Agent /opt/xrce_ws/src/ && \
    rm -rf /opt/src /tmp/dependencies.repos && \
    git -C /opt/px4 submodule update --init --recursive

FROM deps-src AS deps

RUN bash /opt/px4/Tools/setup/ubuntu.sh --no-nuttx --no-sim-tools

RUN source /opt/ros/jazzy/setup.bash && \
    cd /opt/xrce_ws && \
    colcon build --packages-select microxrcedds_agent

RUN source /opt/ros/jazzy/setup.bash && \
    cd /opt/underlay_ws && \
    colcon build --packages-select px4_msgs

RUN source /opt/ros/jazzy/setup.bash && \
    cd /opt/px4 && \
    DONT_RUN=1 make px4_sitl

FROM deps AS workspace

ENV ROS2_WS_AI_ROOT=/workspace/ros2_ws_ai
ENV UNDERLAY_INSTALL=/opt/underlay_ws/install

COPY . /workspace/ros2_ws_ai
WORKDIR /workspace/ros2_ws_ai

RUN source /opt/ros/jazzy/setup.bash && \
    source /opt/underlay_ws/install/setup.bash && \
    colcon build --packages-select inspection_sim robot_control_interfaces robot_control

RUN python3 -m venv /opt/venvs/orchestrator && \
    source /opt/venvs/orchestrator/bin/activate && \
    pip install --upgrade pip && \
    pip install /workspace/ros2_ws_ai/src/sutradhara_orchestrator

FROM base AS runtime

ENV ROS2_WS_AI_ROOT=/workspace/ros2_ws_ai
ENV UNDERLAY_INSTALL=/opt/underlay_ws/install
ENV XRCE_INSTALL=/opt/xrce_ws/install
ENV PX4_DIR=/opt/px4
ENV PX4_BIN=/opt/px4/build/px4_sitl_default/bin/px4
ENV PX4_ROOTFS_BASE=/opt/px4/build/px4_sitl_default/rootfs
ENV PX4_GZ_MODELS_PATH=/opt/px4/Tools/simulation/gz/models
ENV PX4_GZ_WORLDS_PATH=/opt/px4/Tools/simulation/gz/worlds
ENV MICRO_XRCE_AGENT_BIN=/opt/xrce_ws/install/microxrcedds_agent/bin/MicroXRCEAgent
ENV MICRO_XRCE_AGENT_LIB_DIR=/opt/xrce_ws/install/microxrcedds_agent/lib
ENV HOME=/tmp/devhome
ENV UV_CACHE_DIR=/tmp/uv-cache
ENV PATH=/opt/venvs/orchestrator/bin:${PATH}
ENV PYTHONPATH=/workspace/ros2_ws_ai/src/sutradhara_orchestrator

COPY --from=deps /opt/px4 /opt/px4
COPY --from=deps /opt/underlay_ws/install /opt/underlay_ws/install
COPY --from=deps /opt/xrce_ws/install /opt/xrce_ws/install
COPY --from=workspace /opt/venvs/orchestrator /opt/venvs/orchestrator
COPY --from=workspace /workspace/ros2_ws_ai /workspace/ros2_ws_ai

WORKDIR /workspace/ros2_ws_ai

ENTRYPOINT ["/usr/local/bin/ros2_ws_ai_entrypoint.sh"]
CMD ["bash"]
